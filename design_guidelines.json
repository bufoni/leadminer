  "instructions_to_main_agent": [
    "Install 'lucide-react' for icons.",
    "Use 'Outfit' font for headings and 'DM Sans' for body. Import from Google Fonts.",
    "Implement a 'Bento Grid' layout for the Dashboard.",
    "Use 'Recharts' for data visualization (already in package.json).",
    "Ensure all forms use 'react-hook-form' with 'zod' validation.",
    "Use 'sonner' for notifications.",
    "Strictly follow the color palette. Do not use default Tailwind blue.",
    "For the Landing Page Hero: Use the provided background image with a dark gradient overlay.",
    "For Tables: Use a dense layout with sticky headers and pagination.",
    "Add 'data-testid' to all interactive elements."
  ],
  "universal_guidelines": {
    "do_not": [
      "Use 'Inter' font for headings.",
      "Use gradients for text (unless for very specific hero emphasis).",
      "Use rounded-full buttons (unless icon-only).",
      "Center align long paragraphs."
    ],
    "must": [
      "Use proper z-index layering.",
      "Add hover states to ALL interactive elements.",
      "Use skeleton loaders for data fetching states."
    ]
  }
}